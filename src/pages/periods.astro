---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomeHeader from '@/components/HomeHeader.astro';
import { episodeUrl, episodesByPeriod, getEpisodes } from '@/lib/episodes';

const episodes = await getEpisodes();
const grouped = episodesByPeriod(episodes);
---

<BaseLayout title="תקופות" description="האזינו לפודקאסט קדמא לפי סדר תקופות היסטוריות">
  <HomeHeader current="periods" pinned />

  <main class="page-container py-8 lg:py-12">
    <header class="mb-10 border-b border-outline-variant/60 pb-6">
      <h1 class="section-title">תקופות בהיסטוריה</h1>
      <p class="mt-3 max-w-2xl font-body text-body-lg text-on-surface-variant">
        סדר כרונולוגי של פרקי הפודקאסט לפי תקופות היסטוריות
      </p>
    </header>

    {
      grouped.size === 0 ? (
        <p class="rounded border border-dashed border-outline-variant p-6 text-on-surface-variant">
          עדיין לא הוגדרו תקופות. מלאו את <code class="text-ink-blue">migration/period-map.csv</code> והריצו שוב את
          המיגרציה.
        </p>
      ) : (
        <div class="space-y-8">
          {Array.from(grouped.entries()).map(([periodName, periodEpisodes]) => (
            <section class="card p-6 md:p-8">
              <h2 class="mb-6 border-b border-aged-gold/40 pb-3 font-heading text-headline-md font-semibold text-ink-blue">
                {periodName}
              </h2>
              <ol class="divide-y divide-outline-variant/60">
                {periodEpisodes.map((episode, index) => (
                  <li class="flex gap-4 py-4 first:pt-0 last:pb-0">
                    <span class="episode-list-marginalia hidden sm:block">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <a
                      href={episodeUrl(episode)}
                      class="font-heading text-body-lg font-medium text-ink-blue transition hover:text-secondary"
                    >
                      {episode.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </section>
          ))}
        </div>
      )
    }
  </main>
</BaseLayout>
