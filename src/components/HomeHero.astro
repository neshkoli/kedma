---
interface Props {
  pinned?: boolean;
}

const { pinned = false } = Astro.props;
---

<header class="hero-header border-b-4 border-aged-gold">
  <div class="hero-viewport" data-hero-viewport class:list={{ 'hero-viewport-pinned': pinned }}>
    <div class="hero-scale" data-hero-scale>
      <div class="hero-map-track" data-hero-map-track aria-hidden="true">
        <img
          src="/images/background_map.jpg"
          alt=""
          class="hero-map-image"
          width="5162"
          height="1033"
          decoding="async"
          fetchpriority="high"
        />
      </div>
      <div class="hero-gradient" aria-hidden="true"></div>
    </div>
    <div class="hero-text-clip" data-hero-text-clip>
      <div class="hero-text" data-hero-text>
        <h1
          class="hero-line-1 font-tamar text-right leading-none text-[#3d4a2c] hero-title-shadow"
          data-hero-line-1
        >
          קדמא
        </h1>
        <p
          class="hero-line-2 font-tamar text-center leading-none text-ink-blue hero-text-glow"
          data-hero-line-2
        >
          פודקאסט על אנשים וארועים בהיסטוריה היהודית
        </p>
        <p class="hero-line-3 font-tamar text-left leading-none text-[#4a6fa5] hero-text-glow">
          עם נעם אשכולי
        </p>
      </div>
    </div>
  </div>
</header>
