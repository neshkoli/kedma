---
import { formatEpisodeDuration, formatHebrewDate } from '@/lib/episodes';

interface Props {
  date: Date;
  duration?: string;
  textClass?: string;
  class?: string;
}

const {
  date,
  duration,
  textClass = 'label-marginalia',
  class: className,
} = Astro.props;
---

<div class:list={['flex items-center justify-between gap-3', className]}>
  <span class={textClass}>{formatHebrewDate(date)}</span>
  {duration && <span class={textClass}>{formatEpisodeDuration(duration)}</span>}
</div>
